{
  "name": "jackbox-universe",
  "version": "0.2.0",
  "description": "A Windows-first 10-foot launcher for locally installed Jackbox mini-games.",
  "main": "dist/main/index.js",
  "author": "Jackbox Universe",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npm-run-all -p dev:renderer dev:electron",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && npm run build:main && node scripts/start-electron-dev.cjs",
    "build": "npm-run-all clean typecheck test build:main build:renderer",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "clean": "rimraf dist release",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:win": "npm run build && electron-builder --win portable",
    "audit": "node scripts/audit-electron.mjs",
    "audit:artwork": "node scripts/audit-artwork.mjs"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "fast-xml-parser": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.jackboxuniverse.launcher",
    "productName": "Jackbox Universe",
    "icon": "resources/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "Jackbox-Universe-${version}.${ext}"
    }
  }
}
